# ─────────────────────────────────────────────────────────
# Fichier .env.example — à copier en .env et remplir
# NE PAS VERSIONNER le fichier .env réel
# ─────────────────────────────────────────────────────────

# Django
SECRET_KEY=changez-moi-avec-une-valeur-aleatoire-longue
DEBUG=False

# Base de données Supabase / PostgreSQL
DB_PASSWORD=votre_mot_de_passe_de_base_de_donnees_supabase

# Configuration Supabase PostgreSQL (à récupérer de Project Settings > Database sur Supabase)
SQL_DATABASE=postgres
SQL_USER=postgres
SQL_HOST=db.xxxxxx.supabase.co
SQL_PORT=6543
SQL_SSL_MODE=require

# Groq Cloud (https://console.groq.com/keys)
# Service gratuit et ultra-rapide — modèles Llama 3.1
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile
# Alternatives disponibles : llama-3.1-8b-instant, mixtral-8x7b-32768
